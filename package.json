{
    "name": "capacitor-zendesk-support-sdk",
    "version": "1.0.0",
    "description": "Zendesk Support SDK plugin for Capacitor",
    "author": "Paul Bottein",
    "license": "MIT",
    "main": "dist/esm/index.js",
    "types": "dist/esm/index.d.ts",
    "scripts": {
        "build": "npm run clean && tsc",
        "clean": "rm -rf ./dist",
        "watch": "tsc --watch",
        "prepublishOnly": "npm run build"
    },
    "files": [
        "dist/",
        "ios/",
        "android/",
        "CapacitorZendeskChat.podspec",
        "Package.swift"
    ],
    "keywords": [
        "capacitor",
        "capacitor-plugin",
        "zendesk",
        "support-sdk"
    ],
    "capacitor": {
        "ios": {
            "src": "ios"
        },
        "android": {
            "src": "android"
        }
    },
    "peerDependencies": {
        "@capacitor/core": "^8.0.0"
    },
    "devDependencies": {
        "@capacitor/android": "^8.0.0",
        "@capacitor/core": "^8.0.0",
        "@capacitor/ios": "^8.0.0",
        "typescript": "^5.0.0"
    }
}
