{
    "name": "capacitor-zendesk-support-sdk",
    "version": "0.1.3",
    "description": "Zendesk Support SDK plugin for Capacitor",
    "author": "Dimitri Steinel",
    "license": "MIT",
    "homepage": "https://github.com/dsteinel/capacitor-zendesk-support-sdk",
    "repository": {
        "type": "git",
        "url": "https://github.com/dsteinel/capacitor-zendesk-support-sdk.git"
    },
    "main": "dist/esm/index.js",
    "types": "dist/esm/index.d.ts",
    "scripts": {
        "build": "npm run clean && tsc",
        "clean": "rm -rf ./dist",
        "watch": "tsc --watch",
        "prepublishOnly": "npm run build",
        "publish:npm": "npm version patch && npm publish && git push origin --tags"
    },
    "files": [
        "dist/",
        "ios/",
        "android/",
        "CapacitorZendeskSupportSdk.podspec",
        "Package.swift"
    ],
    "keywords": [
        "capacitor",
        "capacitor-plugin",
        "zendesk",
        "support-sdk"
    ],
    "capacitor": {
        "ios": {
            "src": "ios"
        },
        "android": {
            "src": "android"
        }
    },
    "peerDependencies": {
        "@capacitor/core": "^8.0.0"
    },
    "devDependencies": {
        "@capacitor/android": "^8.0.0",
        "@capacitor/core": "^8.0.0",
        "@capacitor/ios": "^8.0.0",
        "typescript": "^5.0.0"
    }
}
